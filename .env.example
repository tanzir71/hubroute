APP_NAME=HubRoute
APP_TIMEZONE=Asia/Dhaka

# On shared hosting, keep DATA_DIR outside public_html if your host allows it.
# Otherwise HubRoute writes .htaccess and index.html denial files into this folder.
DATA_DIR=data

# By default the SQLite database is DATA_DIR/hubroute.sqlite.
# Uncomment only if you need the database file somewhere else.
# DB_PATH=/home/CPANEL_USER/hubroute-data/hubroute.sqlite

SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800

RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_ACTION_ATTEMPTS=60
RATE_LIMIT_ACTION_WINDOW_SECONDS=300

# Set true only during short troubleshooting windows. Never leave enabled in production.
ENABLE_EXTRA_LOGGING=false
