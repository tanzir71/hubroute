{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/cron/maintenance",
      "schedule": "15 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/track",
      "destination": "/track.html"
    },
    {
      "source": "/track/:code",
      "destination": "/track.html?code=:code"
    },
    {
      "source": "/setup",
      "destination": "/setup.html"
    }
  ]
}
