TURSO_DATABASE_URL=libsql://YOUR_DATABASE.turso.io
TURSO_AUTH_TOKEN=replace-with-turso-token
SESSION_SECRET=replace-with-random-32-plus-character-secret
CRON_SECRET=replace-with-random-32-plus-character-secret
SETUP_SECRET=replace-with-random-32-plus-character-secret
APP_TIMEZONE=Asia/Dhaka
MAINTENANCE_PRUNE_TERMINAL_DAYS=180
MAINTENANCE_PRUNE_AUDIT_DAYS=365
MAINTENANCE_PRUNE_IDEMPOTENCY_DAYS=14
